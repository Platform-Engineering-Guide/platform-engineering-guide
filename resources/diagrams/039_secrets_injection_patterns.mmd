flowchart LR
    VAULT["Secret Store\n(Vault / AWS Secrets Manager\n/ GCP Secret Manager)"]

    subgraph P1_SIDECAR["Pattern 1: Sidecar"]
        SIDECAR_CONT["Vault Agent\nsidecar container"]
        MAIN_SIDECAR["Application\ncontainer"]
        SIDECAR_CONT -->|"writes to\nshared volume"| VOL1["tmpfs\nvolume"]
        VOL1 -->|"reads file"| MAIN_SIDECAR
    end

    subgraph P2_INIT["Pattern 2: Init Container"]
        INIT_CONT["Init container\n(runs to completion)"]
        MAIN_INIT["Application\ncontainer"]
        INIT_CONT -->|"writes to\nshared volume\nthen exits"| VOL2["tmpfs\nvolume"]
        VOL2 -->|"reads file\nat startup"| MAIN_INIT
    end

    subgraph P3_CSI["Pattern 3: CSI Driver"]
        CSI["Secrets Store\nCSI Driver\n(DaemonSet)"]
        MAIN_CSI["Application\ncontainer"]
        CSI -->|"mounts secret as\nvolume at pod start"| MAIN_CSI
    end

    subgraph P4_ESO["Pattern 4: External Secrets Operator (Recommended)"]
        ESO["ESO Controller"]
        K8S_SEC["Kubernetes\nSecret object"]
        MAIN_ESO["Application\ncontainer"]
        ESO -->|"creates and\nrotates"| K8S_SEC
        K8S_SEC -->|"env var or\nvolume mount"| MAIN_ESO
    end

    VAULT -->|"Agent auth"| P1_SIDECAR
    VAULT -->|"Init auth"| P2_INIT
    VAULT -->|"CSI auth"| P3_CSI
    VAULT -->|"ESO auth\n(IRSA / Workload Identity)"| P4_ESO

    style P4_ESO fill:#27AE60,color:#fff
    style P3_CSI fill:#2980B9,color:#fff
    style P1_SIDECAR fill:#E67E22,color:#fff
    style P2_INIT fill:#8E44AD,color:#fff
