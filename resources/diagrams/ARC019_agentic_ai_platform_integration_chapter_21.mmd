flowchart LR
    subgraph AgentRuntime["AI Agent Runtime"]
        AGENT["AI Agent\n(LLM + Tool Use)"]
        MCP_CLIENT["MCP Client\n(Model Context Protocol)"]
    end

    subgraph MCPLayer["MCP Server Layer (Platform APIs)"]
        MCP_K8S["MCP Server:\nKubernetes\n(read-only by default)"]
        MCP_OBSERV["MCP Server:\nObservability\n(Grafana / Prometheus)"]
        MCP_INCIDENTS["MCP Server:\nIncident Management\n(PagerDuty / Opsgenie)"]
        MCP_SECRETS["MCP Server:\nSecrets (read-only,\napproval-gated writes)"]
        MCP_IaC["MCP Server:\nIaC Plan Preview\n(no auto-apply)"]
    end

    subgraph Guardrails["Platform Guardrails"]
        AUTHZ["AuthZ Layer\n(RBAC — least privilege)"]
        AUDIT["Audit Log\n(all agent actions)"]
        APPROVAL["Approval Gate\n(human-in-the-loop\nfor write operations)"]
        RATELIMIT["Rate Limiting\n(prevent runaway agents)"]
    end

    AGENT --> MCP_CLIENT
